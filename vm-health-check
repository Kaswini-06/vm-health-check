#!/bin/bash

################################################################################
# VM Health Check Script - FIXED VERSION
# Description: Checks the health of a virtual machine by analyzing CPU, disk
#              space, memory, and other system parameters.
# Usage: ./vm-health-check.sh [--explain]
################################################################################

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Thresholds
CPU_THRESHOLD=80
MEMORY_THRESHOLD=80
DISK_THRESHOLD=80
LOAD_THRESHOLD=4

# Variables to store health status
DECLARE_MODE=""
OVERALL_STATUS="HEALTHY"
STATUS_MESSAGES=""
DETAILED_REPORT=""

################################################################################
# Function: Print colored output
################################################################################
print_status() {
    local status=$1
    local message=$2
    
    case $status in
        "HEALTHY")
            echo -e "${GREEN}✓${NC} $message"
            DETAILED_REPORT+="$(date '+%Y-%m-%d %H:%M:%S') - HEALTHY: $message\n"
            ;;
        "WARNING")
            echo -e "${YELLOW}⚠${NC} $message"
            DETAILED_REPORT+="$(date '+%Y-%m-%d %H:%M:%S') - WARNING: $message\n"
            if [ "$OVERALL_STATUS" = "HEALTHY" ]; then
                OVERALL_STATUS="WARNING"
            fi
            ;;
        "CRITICAL")
            echo -e "${RED}✗${NC} $message"
            DETAILED_REPORT+="$(date '+%Y-%m-%d %H:%M:%S') - CRITICAL: $message\n"
            OVERALL_STATUS="CRITICAL"
            ;;
        "INFO")
            echo -e "${BLUE}ℹ${NC} $message"
            DETAILED_REPORT+="$(date '+%Y-%m-%d %H:%M:%S') - INFO: $message\n"
            ;;
    esac
}

################################################################################
# Function: Check CPU Usage
################################################################################
check_cpu() {
    local cpu_usage=$(top -bn1 | grep "Cpu(s)" | awk '{print int($2 + $4)}')
    
    if [ -z "$cpu_usage" ]; then
        cpu_usage=$(ps aux | awk 'BEGIN {sum=0} {sum+=$3} END {print int(sum)}')
    fi
    
    if [ "$cpu_usage" -ge "$CPU_THRESHOLD" ]; then
        print_status "CRITICAL" "CPU Usage is HIGH: ${cpu_usage}% (Threshold: ${CPU_THRESHOLD}%)"
    elif [ "$cpu_usage" -ge $((CPU_THRESHOLD - 20)) ]; then
        print_status "WARNING" "CPU Usage is ELEVATED: ${cpu_usage}% (Threshold: ${CPU_THRESHOLD}%)"
    else
        print_status "HEALTHY" "CPU Usage is NORMAL: ${cpu_usage}%"
    fi
}

################################################################################
# Function: Check Memory Usage
################################################################################
check_memory() {
    local mem_info=$(free | grep Mem)
    local mem_total=$(echo "$mem_info" | awk '{print int($2/1024)}')
    local mem_used=$(echo "$mem_info" | awk '{print int($3/1024)}')
    local mem_percentage=$((mem_used * 100 / mem_total))
    
    if [ "$mem_percentage" -ge "$MEMORY_THRESHOLD" ]; then
        print_status "CRITICAL" "Memory Usage is HIGH: ${mem_percentage}% (${mem_used}MB / ${mem_total}MB)"
    elif [ "$mem_percentage" -ge $((MEMORY_THRESHOLD - 20)) ]; then
        print_status "WARNING" "Memory Usage is ELEVATED: ${mem_percentage}% (${mem_used}MB / ${mem_total}MB)"
    else
        print_status "HEALTHY" "Memory Usage is NORMAL: ${mem_percentage}% (${mem_used}MB / ${mem_total}MB)"
    fi
}

################################################################################
# Function: Check Disk Space
################################################################################
check_disk() {
    local disk_info=$(df -h / | tail -1)
    local disk_usage=$(echo "$disk_info" | awk '{print int($5)}')
    local disk_available=$(echo "$disk_info" | awk '{print $4}')
    local disk_total=$(echo "$disk_info" | awk '{print $2}')
    
    if [ "$disk_usage" -ge "$DISK_THRESHOLD" ]; then
        print_status "CRITICAL" "Disk Space is LOW: ${disk_usage}% used (${disk_available} free / ${disk_total} total)"
    elif [ "$disk_usage" -ge $((DISK_THRESHOLD - 20)) ]; then
        print_status "WARNING" "Disk Space is TIGHT: ${disk_usage}% used (${disk_available} free / ${disk_total} total)"
    else
        print_status "HEALTHY" "Disk Space is ADEQUATE: ${disk_usage}% used (${disk_available} free / ${disk_total} total)"
    fi
}

################################################################################
# Function: Check System Load
################################################################################
check_load() {
    local load_avg=$(cat /proc/loadavg | awk '{print $1}')
    local load_avg_int=$(printf "%.0f" "$load_avg")
    local cpu_count=$(nproc)
    
    if [ "$load_avg_int" -ge "$LOAD_THRESHOLD" ]; then
        print_status "CRITICAL" "System Load is HIGH: ${load_avg} (CPU Count: ${cpu_count})"
    elif [ "$load_avg_int" -ge $((LOAD_THRESHOLD - 1)) ]; then
        print_status "WARNING" "System Load is ELEVATED: ${load_avg} (CPU Count: ${cpu_count})"
    else
        print_status "HEALTHY" "System Load is NORMAL: ${load_avg} (CPU Count: ${cpu_count})"
    fi
}

################################################################################
# Function: Check Process Count
################################################################################
check_processes() {
    local proc_count=$(ps aux | wc -l)
    local proc_threshold=500
    
    if [ "$proc_count" -ge "$proc_threshold" ]; then
        print_status "WARNING" "High Process Count: ${proc_count} processes running"
    else
        print_status "HEALTHY" "Process Count is NORMAL: ${proc_count} processes"
    fi
}

################################################################################
# Function: Check System Uptime
################################################################################
check_uptime() {
    local uptime_seconds=$(cat /proc/uptime | awk '{print int($1)}')
    local uptime_days=$((uptime_seconds / 86400))
    local uptime_hours=$(((uptime_seconds % 86400) / 3600))
    
    if [ "$uptime_days" -eq 0 ] && [ "$uptime_hours" -lt 1 ]; then
        print_status "WARNING" "System Recently Started: ${uptime_hours} hours uptime"
    else
        print_status "INFO" "System Uptime: ${uptime_days} days, ${uptime_hours} hours"
    fi
}

################################################################################
# Function: Check Network Interfaces
################################################################################
check_network() {
    local active_interfaces=$(ip link show | grep "state UP" | wc -l)
    
    if [ "$active_interfaces" -eq 0 ]; then
        print_status "CRITICAL" "No active network interfaces found"
    else
        print_status "HEALTHY" "Network Interfaces ACTIVE: ${active_interfaces} interface(s) up"
    fi
}

################################################################################
# Function: Display Summary
################################################################################
display_summary() {
    echo ""
    echo -e "${BLUE}================== VM HEALTH SUMMARY ==================${NC}"
    
    case $OVERALL_STATUS in
        "HEALTHY")
            echo -e "${GREEN}Overall Status: $OVERALL_STATUS${NC}"
            ;;
        "WARNING")
            echo -e "${YELLOW}Overall Status: $OVERALL_STATUS${NC}"
            ;;
        "CRITICAL")
            echo -e "${RED}Overall Status: $OVERALL_STATUS${NC}"
            ;;
    esac
    
    echo -e "Scan Time: $(date '+%Y-%m-%d %H:%M:%S')"
    echo -e "${BLUE}======================================================${NC}"
}

################################################################################
# Function: Display Detailed Explanation
################################################################################
display_detailed_explanation() {
    echo ""
    echo -e "${BLUE}================== DETAILED HEALTH REPORT ==================${NC}"
    echo ""
    
    echo -e "${BLUE}Overview:${NC}"
    echo "This report provides a comprehensive analysis of your virtual machine's health."
    echo ""
    
    echo -e "${BLUE}Parameters Analyzed:${NC}"
    echo "1. CPU Usage: Percentage of CPU currently in use"
    echo "   - Normal: < 60%"
    echo "   - Warning: 60-80%"
    echo "   - Critical: >= 80%"
    echo ""
    echo "2. Memory Usage: Percentage of RAM currently in use"
    echo "   - Normal: < 60%"
    echo "   - Warning: 60-80%"
    echo "   - Critical: >= 80%"
    echo ""
    echo "3. Disk Space: Percentage of disk currently used"
    echo "   - Normal: < 60%"
    echo "   - Warning: 60-80%"
    echo "   - Critical: >= 80%"
    echo ""
    echo "4. System Load: Average load over 1 minute"
    echo "   - Normal: < 3"
    echo "   - Warning: 3-4"
    echo "   - Critical: >= 4"
    echo ""
    echo "5. Process Count: Number of running processes"
    echo "   - Normal: < 500 processes"
    echo "   - Warning: >= 500 processes"
    echo ""
    echo "6. System Uptime: Time since last reboot"
    echo "   - Recent Restart: < 1 hour (warning to investigate)"
    echo ""
    echo "7. Network Interfaces: Status of network connectivity"
    echo "   - Critical: No active interfaces"
    echo "   - Healthy: One or more interfaces active"
    echo ""
    
    echo -e "${BLUE}Detailed Scan Results:${NC}"
    echo -e "$DETAILED_REPORT"
    echo ""
    
    echo -e "${BLUE}Recommendations:${NC}"
    if [[ "$OVERALL_STATUS" == "CRITICAL" ]]; then
        echo "• Your VM is experiencing critical issues."
        echo "• Investigate resource bottlenecks immediately."
        echo "• Consider scaling resources or optimizing applications."
    elif [[ "$OVERALL_STATUS" == "WARNING" ]]; then
        echo "• Your VM has elevated resource usage."
        echo "• Monitor trends to prevent performance degradation."
        echo "• Plan resource optimization in the near term."
    else
        echo "• Your VM is operating normally."
        echo "• Continue regular monitoring for optimal performance."
    fi
    
    echo ""
    echo -e "${BLUE}================= END OF DETAILED REPORT ==================${NC}"
}

################################################################################
# Main Execution
################################################################################
main() {
    # Parse command-line arguments
    for arg in "$@"; do
        case "$arg" in
            --explain)
                DECLARE_MODE="explain"
                ;;
            -h|--help)
                echo "Usage: $0 [OPTIONS]"
                echo ""
                echo "Options:"
                echo "  --explain    Display detailed health status summary"
                echo "  -h, --help   Show this help message"
                exit 0
                ;;
        esac
    done
    
    echo -e "${BLUE}Starting VM Health Check...${NC}"
    echo ""
    
    # Run all health checks
    check_cpu
    check_memory
    check_disk
    check_load
    check_processes
    check_uptime
    check_network
    
    # Display summary
    display_summary
    
    # Display detailed explanation if requested
    if [ "$DECLARE_MODE" = "explain" ]; then
        display_detailed_explanation
    fi
}

# Execute main function
main "$@"
